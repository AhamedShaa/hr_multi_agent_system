# ── LLM ──────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-your-key-here
MODEL_NAME=openai/gpt-4o-mini

# ── Intent Classifier ─────────────────────────────────────────────────────────
# Requests below this confidence are routed to ClarificationAgent (range: 0.0-1.0)
CLASSIFIER_CONFIDENCE_THRESHOLD=0.6
# LLM call timeout in seconds
CLASSIFIER_TIMEOUT_SECONDS=10
# Number of retry attempts on LLM failure
CLASSIFIER_MAX_RETRIES=3
# Seconds to wait between retries
CLASSIFIER_RETRY_DELAY=1.0

# ── Short-Term Memory (STM) ───────────────────────────────────────────────────
# Maximum entries stored per session
STM_MAX_ENTRIES=10
# Hours before STM entries expire (session context window)
STM_TTL_HOURS=24
# How many STM entries are injected into the LLM classification prompt
STM_CONTEXT_INJECTION_LIMIT=3

# ── Long-Term Memory (LTM) ────────────────────────────────────────────────────
# Significance score required to promote STM -> LTM (range: 0.0-1.0)
LTM_SIGNIFICANCE_THRESHOLD=0.6
# Maximum LTM entries retained per user (oldest/lowest-score evicted above this)
LTM_MAX_ENTRIES_PER_USER=100
# Maximum LTM entries returned per retrieval query
LTM_RETRIEVAL_LIMIT=5

# ── Sub-Agents ────────────────────────────────────────────────────────────────
# Per-agent LLM call timeout in seconds
AGENT_TIMEOUT_SECONDS=30
# Retry attempts on agent LLM failure
AGENT_MAX_RETRIES=3
# Seconds to wait between agent retries
AGENT_RETRY_DELAY=1.0

# ── API / Endpoints ───────────────────────────────────────────────────────────
# Maximum character length of user message input
MAX_MESSAGE_LENGTH=2000
# Maximum page size for GET /audit (hard cap enforced server-side)
AUDIT_PAGE_LIMIT_MAX=200
# Comma-separated CORS origins ("*" allows all -- restrict in production)
CORS_ORIGINS=["*"]

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./hr_system.db
# Fallback file when DB audit insert fails (append-only JSONL)
AUDIT_FALLBACK_FILE=audit_fallback.jsonl

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
APP_VERSION=1.0.0
